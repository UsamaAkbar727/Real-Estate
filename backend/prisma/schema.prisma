// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Agent {
  id          Int        @id @default(autoincrement())
  slug        String     @unique
  name        String
  role        String
  bio         String
  experience  String
  deals       Int
  sales       String
  specialties String     // Comma-separated strings e.g. "DHA, Bahria Town, Plots"
  image       String
  phone       String
  email       String
  createdAt   DateTime   @default(now())
  properties  Property[]
}

model Property {
  id           Int      @id @default(autoincrement())
  slug         String   @unique
  title        String
  location     String
  areaName     String
  price        String
  priceValue   Float
  pricePerSqft String?
  type         String   // "Sale" | "Rent"
  category     String   // "Villa" | "Apartment" | "Penthouse" etc.
  beds         Int
  baths        Int
  area         String   // e.g. "1 Kanal", "10 Marla"
  image        String
  gallery      String   // Comma-separated list of image URLs e.g. "url1,url2,url3"
  tag          String?  // e.g. "Signature", "Hot Deal"
  featured     Boolean  @default(false)
  coordinatesX Float
  coordinatesY Float
  description  String
  features     String   // Comma-separated list of features e.g. "Pool,Garage,Garden"
  agentId      Int
  agent        Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  yearBuilt    Int
  parking      Int?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Inquiry {
  id        Int      @id @default(autoincrement())
  name      String
  email     String
  phone     String
  interest  String
  message   String
  createdAt DateTime @default(now())
}